<?xml version="1.0" encoding="utf-8"?><!--
    Network Security Configuration
    Allows cleartext HTTP traffic to localhost aliases used during local development.
    Production traffic must go through HTTPS only.
-->
<network-security-config>
    <!-- Allow cleartext to emulator localhost and LAN IPs in debug builds only -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator → host machine's localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Real device → PC's LAN IP (update if your IP changes) -->
        <domain includeSubdomains="false">192.168.10.58</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!-- Cleartext allowed globally — users may configure http:// server endpoints -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
